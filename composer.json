{
    "name": "machour/laravel-data-table",
    "description": "A reusable, server-side DataTable system for Laravel + Inertia.js + React (TanStack Table). Define your table in a single PHP class — get sorting, filtering, pagination, exports, quick views, and a full-featured React UI out of the box.",
    "keywords": ["laravel", "datatable", "inertia", "react", "tanstack-table", "spatie"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/http": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0",
        "spatie/laravel-data": "^4.0",
        "spatie/laravel-query-builder": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "mockery/mockery": "^1.6"
    },
    "suggest": {
        "maatwebsite/excel": "Required for XLSX/CSV export functionality (^3.1)",
        "spatie/laravel-typescript-transformer": "Generate TypeScript types from the PHP DTOs (^2.5)"
    },
    "autoload": {
        "psr-4": {
            "Machour\\DataTable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Machour\\DataTable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Machour\\DataTable\\DataTableServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
